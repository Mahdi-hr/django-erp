DJANGO_SECRET_KEY=your-secret-key-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://erp_user:erp_password@localhost:5432/erp_db

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# SMS Providers
KAVENEGAR_API_KEY=your-kavenegar-api-key
KAVENEGAR_SENDER_NUMBER=your-sender-number
SMSIR_API_KEY=your-smsir-api-key
SMSIR_SENDER_NUMBER=your-sender-number

# Celery
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# GitHub Repository (for auto-update)
GITHUB_REPO_URL=https://github.com/Mahdi-hr/django-erp.git
